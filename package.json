{
  "name": "@eva_solutions/auth-sdk",
  "version": "1.1.0",
  "description": "Official TypeScript client for the EVA Auth Service — secure cookie-based auth with JWT ES256, JWKS rotation, S2S signing, and webhooks.",
  "keywords": [
    "auth",
    "sdk",
    "typescript",
    "jwt",
    "jwks",
    "hono",
    "react",
    "cookies",
    "es256",
    "eva",
    "security",
    "oauth",
    "session"
  ],
  "homepage": "https://github.com/eva-solutions-org/auth-sdk#readme",
  "bugs": {
    "url": "https://github.com/eva-solutions-org/auth-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eva-solutions-org/auth-sdk.git"
  },
  "license": "MIT",
  "author": "EVA Solutions <arturo.rodas.gonzales@gmail.com>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/eva-solutions-org"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono/index.d.ts",
        "default": "./dist/hono/index.js"
      },
      "require": {
        "types": "./dist/hono/index.d.cts",
        "default": "./dist/hono/index.cjs"
      }
    },
    "./generic": {
      "import": {
        "types": "./dist/generic/index.d.ts",
        "default": "./dist/generic/index.js"
      },
      "require": {
        "types": "./dist/generic/index.d.cts",
        "default": "./dist/generic/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./hono-openapi": {
      "import": {
        "types": "./dist/hono-openapi/index.d.ts",
        "default": "./dist/hono-openapi/index.js"
      },
      "require": {
        "types": "./dist/hono-openapi/index.d.cts",
        "default": "./dist/hono-openapi/index.cjs"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks/index.d.ts",
        "default": "./dist/webhooks/index.js"
      },
      "require": {
        "types": "./dist/webhooks/index.d.cts",
        "default": "./dist/webhooks/index.cjs"
      }
    },
    "./admin": {
      "import": {
        "types": "./dist/admin/index.d.ts",
        "default": "./dist/admin/index.js"
      },
      "require": {
        "types": "./dist/admin/index.d.cts",
        "default": "./dist/admin/index.cjs"
      }
    },
    "./s2s": {
      "import": {
        "types": "./dist/s2s/index.d.ts",
        "default": "./dist/s2s/index.js"
      },
      "require": {
        "types": "./dist/s2s/index.d.cts",
        "default": "./dist/s2s/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:local": "cross-env EVA_BUILD_ENV=local tsdown",
    "build:dev": "cross-env EVA_BUILD_ENV=development tsdown",
    "build:prod": "cross-env EVA_BUILD_ENV=production tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:types": "vitest run --typecheck.only",
    "lint": "oxlint .",
    "fmt": "oxfmt --write src/",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run lint && pnpm run type-check && pnpm run test:run && pnpm run build:prod",
    "pack:local": "pnpm run build:local && pnpm pack",
    "changeset": "changeset",
    "version": "changeset version",
    "docs": "typedoc",
    "attw": "attw --pack . --ignore-rules no-resolution"
  },
  "peerDependencies": {
    "@hono/zod-openapi": ">=1.4.0",
    "hono": ">=4.12.19",
    "react": ">=19.2.6"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "@hono/zod-openapi": {
      "optional": true
    }
  },
  "dependencies": {
    "bowser": "^2.14.1",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.31.0",
    "@hono/zod-openapi": "^1.4.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@typhonjs-typedoc/typedoc-theme-dmt": "^0.4.0",
    "cross-env": "^10.1.0",
    "expect-type": "^1.3.0",
    "hono": "^4.12.19",
    "oxlint": "^1.65.0",
    "react": "^19.2.6",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.1.2"
}
