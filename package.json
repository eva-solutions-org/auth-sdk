{
  "name": "@eva_solutions/auth-sdk",
  "version": "1.0.0",
  "description": "Official TypeScript client for the EVA Auth Service — secure cookie-based auth with JWT ES256, JWKS rotation, S2S signing, and webhooks.",
  "keywords": [
    "auth",
    "sdk",
    "typescript",
    "jwt",
    "jwks",
    "hono",
    "react",
    "cookies",
    "es256",
    "eva",
    "security",
    "oauth",
    "session"
  ],
  "homepage": "https://github.com/eva-solutions-org/auth-sdk#readme",
  "bugs": {
    "url": "https://github.com/eva-solutions-org/auth-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eva-solutions-org/auth-sdk.git"
  },
  "license": "MIT",
  "author": "EVA Solutions <arturo.rodas.gonzales@gmail.com>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/eva-solutions-org"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js",
      "require": "./dist/hono/index.cjs"
    },
    "./generic": {
      "types": "./dist/generic/index.d.ts",
      "import": "./dist/generic/index.js",
      "require": "./dist/generic/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./hono-openapi": {
      "types": "./dist/hono-openapi/index.d.ts",
      "import": "./dist/hono-openapi/index.js",
      "require": "./dist/hono-openapi/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js",
      "require": "./dist/webhooks/index.cjs"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "require": "./dist/admin/index.cjs"
    },
    "./s2s": {
      "types": "./dist/s2s/index.d.ts",
      "import": "./dist/s2s/index.js",
      "require": "./dist/s2s/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:local": "cross-env EVA_BUILD_ENV=local tsup",
    "build:dev": "cross-env EVA_BUILD_ENV=development tsup",
    "build:prod": "cross-env EVA_BUILD_ENV=production tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:types": "vitest run --typecheck.only",
    "lint": "oxlint .",
    "fmt": "oxfmt --write src/",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run lint && pnpm run type-check && pnpm run test:run && pnpm run build:prod",
    "pack:local": "pnpm run build:local && pnpm pack",
    "changeset": "changeset",
    "version": "changeset version",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "react": ">=18.0.0",
    "@hono/zod-openapi": ">=1.3.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "@hono/zod-openapi": {
      "optional": true
    }
  },
  "dependencies": {
    "bowser": "^2.14.0",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@hono/zod-openapi": "^1.3.0",
    "@typhonjs-typedoc/typedoc-theme-dmt": "^0.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "cross-env": "^10.1.0",
    "expect-type": "^1.3.0",
    "hono": "^4.7.0",
    "oxlint": "^1.59.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.6.3"
}
