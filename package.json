{
  "name": "@eva/auth-sdk",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js",
      "require": "./dist/hono/index.cjs"
    },
    "./generic": {
      "types": "./dist/generic/index.d.ts",
      "import": "./dist/generic/index.js",
      "require": "./dist/generic/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:local": "cross-env EVA_BUILD_ENV=local tsup",
    "build:dev": "cross-env EVA_BUILD_ENV=development tsup",
    "build:prod": "cross-env EVA_BUILD_ENV=production tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint .",
    "fmt": "oxfmt --write src/",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run type-check && pnpm run test:run && pnpm run build:prod",
    "pack:local": "pnpm run build:local && pnpm pack"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "bowser": "^2.14.0",
    "jose": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "cross-env": "^10.1.0",
    "hono": "^4.7.0",
    "oxlint": "^1.59.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
